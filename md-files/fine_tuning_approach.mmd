flowchart LR
 subgraph Sequences["Frame Sequences"]
    direction TB
        S1["Sequence 1<br>(DICOM)"]
        S2["Sequence 2<br>(DICOM)"]
        Sdots["..."]
        SN["Sequence N<br>(DICOM)"]
  end
 subgraph Encoders["Vision Encoders (Trainable)"]
    direction TB
        VE1["Vision Encoder 1"]
        VE2["Vision Encoder 2"]
        VEdots["..."]
        VEN["Vision Encoder N"]
  end
 subgraph Features["Extracted Features"]
    direction TB
        F1["Features 1"]
        F2["Features 2"]
        Fdots["..."]
        FN["Features N"]
  end
 subgraph Study["Study (One Report)"]
    direction LR
        Start["Study Input"]
        VisualFrames["Visual Frames"]
        TextualReports["Textual Reports"]
        Sequences
        Encoders
        Features
        Merge["Merge Layer<br>(Fusion)"]
        MergedVisualFeatures["Merged<br>Visual Features"]
        LLM["Language Model<br>(Frozen)"]
        TextFeatures["Text Features"]
        CLIP["Contrastive Training<br>(CLIP)"]
        Output["Final Output"]
  end
    Start --> VisualFrames & TextualReports
    VisualFrames --> Sequences
    S1 --> VE1
    S2 --> VE2
    SN --> VEN
    VE1 --> F1
    VE2 --> F2
    VEN --> FN
    F1 --> Merge
    F2 --> Merge
    FN --> Merge
    Merge --> MergedVisualFeatures
    TextualReports --> LLM
    LLM --> TextFeatures
    MergedVisualFeatures --> CLIP
    TextFeatures --> CLIP
    CLIP --> Output

     S1:::data
     S2:::data
     Sdots:::dots
     SN:::data
     VE1:::trainable
